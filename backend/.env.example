# 可选数据源 API Key 配置
# 复制本文件为 .env，填入对应 Key 即可启用对应数据源
# 没有的 Key 留空或删除该行，不影响其他数据源正常使用

# CORE（1.7 亿+ 开放获取论文）
# 获取地址：https://core.ac.uk/services/api
CORE_API_KEY=

# NASA ADS（天文 / 天体物理 / 地球科学）
# 获取地址：https://ui.adsabs.harvard.edu/user/settings/token
NASA_ADS_API_KEY=

# SerpAPI（Google Scholar 搜索，SerpAPI 方案备用）
# 获取地址：https://serpapi.com → 注册后免费 250 次/月
SERPAPI_KEY=

# 服务器代理地址（scholarly 方案优先，格式 http://host:port）
# 留空则 scholarly 不走代理（容易被 Google 封），无代理时自动回退到 SerpAPI
PROXY_URL=
