# 可选数据源 API Key 配置
# 复制本文件为 .env，填入对应 Key 即可启用对应数据源
# 没有的 Key 留空或删除该行，不影响其他数据源正常使用

# ── 数据库（生产环境推荐 PostgreSQL） ──────────────────────────
# 留空则自动使用本地 SQLite（./scholarscout.db）
# 示例：DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/scholarscout
DATABASE_URL=

# ── Redis（可选，用于搜索结果缓存加速）────────────────────────
# 留空则禁用缓存，不影响功能
# 示例：REDIS_URL=redis://localhost:6379/0
REDIS_URL=
# 缓存搜索结果保留时间（秒），默认 3600
CACHE_SEARCH_TTL=3600

# CORE（1.7 亿+ 开放获取论文）
# 获取地址：https://core.ac.uk/services/api
CORE_API_KEY=

# NASA ADS（天文 / 天体物理 / 地球科学）
# 获取地址：https://ui.adsabs.harvard.edu/user/settings/token
NASA_ADS_API_KEY=

# SerpAPI（Google Scholar 搜索，SerpAPI 方案备用）
# 获取地址：https://serpapi.com → 注册后免费 250 次/月
SERPAPI_KEY=

# 服务器代理地址（scholarly 方案优先，格式 http://host:port）
# 留空则 scholarly 不走代理（容易被 Google 封），无代理时自动回退到 SerpAPI
PROXY_URL=

# ── 可观测性（可选）─────────────────────────────────────────────
# Sentry 错误追踪（https://sentry.io → 新建项目 → 获取 DSN）
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# 性能追踪采样率（0.0–1.0），0.1 = 采样 10% 请求
SENTRY_TRACES_SAMPLE_RATE=0.1

# 日志格式：console（彩色控制台）| json（结构化 JSON，适合 Loki/Datadog）
LOG_FORMAT=console
LOG_LEVEL=INFO
